        <enumeratedValueSet variable="landscape_type">
          <value value="&quot;Random natural&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="seed-percent">
          <value value="1.0E-4"></value>
          <value value="0.01"></value>
          <value value="1"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="number-of-days">
          <value value="3"></value>
        </enumeratedValueSet>
